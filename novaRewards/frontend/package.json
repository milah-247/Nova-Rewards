    "canvas-confetti": "^1.9.4",
    "framer-motion": "^11.2.0",
    "lucide-react": "^0.395.0",
    "next": "^15.5.15",
    "next-i18next": "^14.0.3",
    "next-themes": "^0.4.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-joyride": "^2.9.3",
    "recharts": "^3.8.1",
    "socket.io-client": "^4.7.5",
    "stellar-sdk": "^12.3.0",
    "swr": "^2.4.1",
    "tailwind-merge": "^2.6.1",
    "zod": "^4.3.6",
    "zustand": "^4.5.2"
