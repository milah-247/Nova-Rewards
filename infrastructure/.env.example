# Environment Variables for Infrastructure Components

# ==================== DATABASE ====================
DB_HOST=postgres-staging
DB_PORT=5432
DB_USER=staging_user
DB_PASSWORD=staging_password
DB_NAME=nova_rewards_staging

# ==================== REDIS ====================
REDIS_URL=redis://redis-staging:6379
REDIS_HOST=redis-staging
REDIS_PORT=6379

# ==================== VAULT ====================
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=s.XXXXXXXXXXXXXXXX
VAULT_SKIP_VERIFY=false
VAULT_NAMESPACE=

# ==================== AWS ====================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=XXXXXXXXXX
AWS_SECRET_ACCESS_KEY=XXXXXXXXXXXXXXX
AWS_ACCOUNT_ID=123456789012

# ==================== CLOUDFLARE ====================
CLOUDFLARE_API_TOKEN=XXXXXXXXXXXXXXXXXXXXX
CLOUDFLARE_ACCOUNT_ID=XXXXXXXX
CLOUDFLARE_ZONE_ID=XXXXXXXX

# ==================== LOGGING ====================
LOKI_URL=http://loki:3100
PROMETHEUS_URL=http://prometheus:9090
PROMETHEUS_RETENTION=30d
LOG_LEVEL=info
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXXX/XXXX/XXXX

# ==================== MONITORING ====================
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_ADMIN_USER=admin
GRAFANA_DATASOURCE_PROMETHEUS=http://prometheus:9090
GRAFANA_DATASOURCE_LOKI=http://loki:3100

# ==================== APPLICATION ====================
NODE_ENV=staging
API_PORT=3001
API_URL=http://backend-staging:3001
FRONTEND_URL=http://frontend-staging:3000
REACT_APP_API_URL=http://backend-staging:3001
REACT_APP_ENV=staging

# ==================== SECRET ROTATION ====================
ROTATION_INTERVAL=86400  # 24 hours
SECRET_ROTATION_ENABLED=true
DB_ROTATION_ENABLED=true
API_KEY_ROTATION_ENABLED=true

# ==================== ENVIRONMENT SPECIFIC ====================
ENVIRONMENT=staging
STAGING_DATABASE_URL=postgres://staging_user:staging_password@postgres-staging:5432/nova_rewards_staging
STAGING_REDIS_URL=redis://redis-staging:6379
PRODUCTION_DATABASE_URL=postgres://user:password@prod-db.internal:5432/nova_rewards_prod
PRODUCTION_REDIS_URL=redis://prod-redis.internal:6379

# ==================== HEROKU (for preview deployments) ====================
HEROKU_API_KEY=XXXXXXXXXXXXXXX
HEROKU_APP_NAME=pr-{PR_NUMBER}-nova-rewards

# ==================== TESTING ====================
TEST_DATABASE_URL=postgres://test_user:test_password@postgres-staging:5432/nova_rewards_test
SEED_DATABASE=true
SEED_WITH_TEST_DATA=true
