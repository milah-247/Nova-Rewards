# Frontend environment variables (Next.js)
# Copy this file to .env.local and fill in real values.
# NEXT_PUBLIC_* vars are embedded in the browser bundle — never put secrets here.

# Backend API base URL
NEXT_PUBLIC_API_URL=http://localhost:3001

# Stellar Horizon endpoint
NEXT_PUBLIC_HORIZON_URL=https://horizon-testnet.stellar.org

# Stellar issuer public key (safe to expose — public key only)
NEXT_PUBLIC_ISSUER_PUBLIC=GXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Stellar network identifier: testnet | mainnet
NEXT_PUBLIC_STELLAR_NETWORK=testnet

# Sentry Configuration (for error monitoring)
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
NEXT_PUBLIC_ENVIRONMENT=development
SENTRY_ORG=your-org
SENTRY_PROJECT=your-project
SENTRY_AUTH_TOKEN=your-auth-token

