{
  "name": "nova-rewards-backend",
  "version": "1.0.0",
  "description": "NovaRewards backend API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --runInBand --coverage",
    "test:ci": "jest --runInBand --ci --coverage --json --outputFile=test-results/results.json --reporters=default --reporters=jest-junit",
    "lint": "eslint .",
    "migrate": "node ../database/migrate.js",
    "migrate:rollback": "node ../database/migrate.js --rollback",
    "db:migrate": "node ../database/migrate.js",
    "generate:openapi": "node -e \"const fs=require('fs'); const swagger=require('./swagger'); fs.mkdirSync('../..//docs', { recursive: true}); fs.writeFileSync('../../docs/openapi.json', JSON.stringify(swagger, null, 2)); console.log('docs/openapi.json generated');\""  
  },
  "dependencies": {
    "@elastic/elasticsearch": "^8.13.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.3.1",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^8.0.4",
    "pg": "^8.12.0",
    "prom-client": "^15.1.3",
    "rate-limit-redis": "^4.2.0",
    "redis": "^4.7.0",
    "socket.io": "^4.8.3",
    "stellar-sdk": "^12.3.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^10.0.0",
    "@aws-sdk/client-secrets-manager": "^3.0.0"
  },
  "devDependencies": {
    "fast-check": "^3.23.2",
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "nodemon": "^3.1.14",
    "supertest": "^6.3.3"
  },
  "jest-junit": {
    "outputDirectory": "test-results",
    "outputName": "junit.xml"
  }
}
